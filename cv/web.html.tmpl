<!DOCTYPE html>
<html lang="en" dir="auto" data-theme="auto">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>CV — Massimiliano Aroffo</title>
    <meta name="description" content="Massimiliano Aroffo — Principal Engineer (agentic security) and Cloud Architect. 25 years in software, now hands-on in Go on GCP.">
    <meta name="author" content="Maroffo">
    <link rel="canonical" href="https://maroffo.github.io/cv/">
    <meta name="theme-color" content="#23272b">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Literata:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <script>
        if (localStorage.getItem("pref-theme") === "dark") {
            document.querySelector("html").dataset.theme = 'dark';
        } else if (localStorage.getItem("pref-theme") === "light") {
            document.querySelector("html").dataset.theme = 'light';
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.querySelector("html").dataset.theme = 'dark';
        } else {
            document.querySelector("html").dataset.theme = 'light';
        }
    </script>
    <style>
        :root {
            --gap: 24px; --nav-width: 1024px; --main-width: 820px;
            --header-height: 60px; --footer-height: 60px; --radius: 8px;
            --theme: #f0e7d4; --entry: #f0e7d4; --primary: #5a5e6b;
            --secondary: #5a6a4d; --tertiary: #d4c7a4; --content: #5a5e6b;
            --border: #d4c7a4;
            --nur-accent: #fc7261; --nur-link: #9d80b7; --nur-link-hover: #6fa3d2;
            --nur-selection: #8ebdb6;
            color-scheme: light;
        }
        :root[data-theme="dark"] {
            --theme: #23272b; --entry: #1d2024; --primary: #e2dbc4;
            --secondary: #6e7f5c; --tertiary: #3a4540; --content: #e2dbc4;
            --border: #3a4540;
            --nur-accent: #fc7261; --nur-link: #9d80b7; --nur-link-hover: #6fa3d2;
            --nur-selection: #8ebdb6;
            color-scheme: dark;
        }
        ::selection { background: var(--nur-selection); color: var(--primary); }
        *, ::after, ::before { box-sizing: border-box; }
        html { -webkit-tap-highlight-color: transparent; overflow-y: scroll; }
        a, button, body, h1, h2, h3, h4 { color: var(--primary); }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            font-size: 15px; line-height: 1.55; word-break: break-word;
            background: var(--theme); margin: 0;
        }
        a { text-decoration: none; }
        ul { padding: 0; margin: 0; list-style: none; }

        /* Header / Nav (mirrors the landing page) */
        .nav {
            display: flex; flex-wrap: wrap; justify-content: space-between;
            max-width: calc(var(--nav-width) + var(--gap) * 2);
            margin-inline: auto; line-height: var(--header-height);
        }
        .nav a { display: block; }
        .logo, #menu { display: flex; margin: auto var(--gap); }
        .logo a { font-size: 24px; font-weight: 700; }
        .logo-switches { display: inline-flex; margin: auto 4px; }
        button#theme-toggle {
            font-size: 26px; margin: auto 4px; padding: 0;
            font: inherit; background: 0 0; border: 0; cursor: pointer;
        }
        [data-theme="dark"] #moon { display: none; }
        [data-theme="light"] #sun { display: none; }
        #menu { list-style: none; word-break: keep-all; overflow-x: auto; white-space: nowrap; }
        #menu li + li { margin-inline-start: var(--gap); }
        #menu a { font-size: 16px; }
        #menu .active { font-weight: 600; border-bottom: 2px solid var(--nur-accent); }

        /* Main */
        .main {
            max-width: calc(var(--main-width) + var(--gap) * 2);
            margin: auto; padding: var(--gap);
        }
        .actions { display: flex; gap: 12px; margin: 8px 0 4px; flex-wrap: wrap; }
        .btn {
            display: inline-block; font-weight: 600; font-size: 14px;
            color: var(--nur-accent); background: var(--entry);
            border: 1px solid var(--nur-accent); border-radius: var(--radius);
            padding: 7px 16px; transition: background .2s, color .2s;
        }
        .btn:hover { background: var(--nur-accent); color: #fff; }

        /* CV content */
        .cv h1 { font-size: 34px; line-height: 1.2; margin: 18px 0 4px; }
        .cv h1 + p { color: var(--secondary); font-size: 14px; margin: 0 0 4px; }
        .cv h2 {
            color: var(--nur-accent); font-size: 14px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px;
            margin: 30px 0 12px; padding-bottom: 5px; border-bottom: 1px solid var(--border);
        }
        .cv h3 {
            color: var(--secondary); font-size: 11px; font-weight: 600;
            letter-spacing: 1px; text-transform: uppercase; margin: 20px 0 2px;
        }
        .cv h3 + p { margin: 0 0 8px; line-height: 1.4; }
        .cv h3 + p strong { font-size: 17px; font-weight: 700; }
        .cv h3 + p em { color: var(--secondary); font-style: normal; font-size: 13px; }
        .cv p { margin: 0 0 9px; }
        .cv strong { color: var(--primary); font-weight: 700; }
        .cv ul { padding-inline-start: 20px; margin: 4px 0 10px; list-style: disc; }
        .cv li { margin-top: 3px; }
        .cv a { color: var(--nur-link); box-shadow: 0 1px; }
        .cv a:hover { color: var(--nur-link-hover); }

        /* Footer */
        .footer {
            font-size: 12px; color: var(--secondary);
            max-width: calc(var(--main-width) + var(--gap) * 2);
            margin: auto; padding: 18px var(--gap) 40px; text-align: center;
        }
        .footer a { color: inherit; border-bottom: 1px solid var(--secondary); }
        .footer a:hover { color: var(--nur-link-hover); }

        ::-webkit-scrollbar-track { background: 0 0; }
        ::-webkit-scrollbar-thumb { background: var(--tertiary); border: 5px solid var(--theme); border-radius: var(--radius); }
        ::-webkit-scrollbar-thumb:hover { background: var(--secondary); }

        @media screen and (max-width: 768px) {
            :root { --gap: 14px; }
            .cv h1 { font-size: 28px; }
        }
    </style>
</head>

<body id="top">
    <header class="header">
        <nav class="nav">
            <div class="logo">
                <a href="/" accesskey="h" title="Maroffo (Alt + H)">Maroffo</a>
                <div class="logo-switches">
                    <button id="theme-toggle" accesskey="t" title="(Alt + T)" aria-label="Toggle theme">
                        <svg id="moon" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                        <svg id="sun" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                    </button>
                </div>
            </div>
            <ul id="menu">
                <li><a href="/blog/" title="Blog"><span>Blog</span></a></li>
                <li><a href="/blog/about/" title="About"><span>About</span></a></li>
                <li><a href="/cv/" class="active" title="CV"><span>CV</span></a></li>
            </ul>
        </nav>
    </header>

    <main class="main">
        <div class="actions">
            <a href="cv.pdf" class="btn" download>Download PDF</a>
            <a href="/" class="btn">Back to home</a>
        </div>
        <article class="cv">
{{CONTENT}}
        </article>
    </main>

    <footer class="footer">
        <span>&copy; 2026 <a href="/">Maroffo</a>. Last updated June 2026.</span>
    </footer>

    <script>
        document.getElementById("theme-toggle").addEventListener("click", () => {
            const html = document.querySelector("html");
            if (html.dataset.theme === "dark") {
                html.dataset.theme = 'light';
                localStorage.setItem("pref-theme", 'light');
            } else {
                html.dataset.theme = 'dark';
                localStorage.setItem("pref-theme", 'dark');
            }
        });
    </script>
</body>
</html>
